# Ollama Configuration
# Host URL for the Ollama service (internal Docker network)
OLLAMA_HOST=http://ollama:11434

# LLM model for chat completions (phi3.5 recommended for low vRAM systems)
LLM_MODEL=phi3.5

# Embedding model for vector generation
EMBED_MODEL=nomic-embed-text

# Number of GPU layers to offload (set to 0 to force CPU-only)
OLLAMA_NUM_GPU=1

# Qdrant Configuration
# Host URL for the Qdrant vector database (internal Docker network)
QDRANT_HOST=http://qdrant:6333

# Name of the Qdrant collection to store document vectors
QDRANT_COLLECTION=books

# Backend Configuration
# Directory where uploaded files are stored
UPLOAD_DIR=/app/uploads

# Path to the SQLite database file
DB_PATH=/app/data/db.sqlite

# Maximum upload file size in megabytes
MAX_UPLOAD_SIZE_MB=200

# Child chunk size in tokens (used for vector search)
CHUNK_SIZE=300

# Overlap between consecutive child chunks in tokens
CHUNK_OVERLAP=50

# Parent chunk size in tokens (used as LLM context)
PARENT_CHUNK_SIZE=1000

# Number of top results to return from hybrid search
TOP_K_RESULTS=6

# Frontend Configuration
# Backend API URL (used by Next.js to proxy API calls)
NEXT_PUBLIC_API_URL=http://localhost:8000
